{
  "name": "hercules-reporting-module",
  "version": "1.0.0",
  "description": "Hercules Reporting Module - Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "Hercules",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.hercules.reporting",
    "productName": "Hercules Reporting Module",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "../backend/dist/hercules-backend",
        "to": "backend"
      },
      {
        "from": "pgsql",
        "to": "pgsql"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "license-pending.html",
      "license-denied.html",
      "setup-wizard.html",
      "icons/**"
    ]
  }
}
